[Unit]
Description=OxidERP Core Server
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=oxiderp
Group=oxiderp
WorkingDirectory=/opt/oxiderp
EnvironmentFile=/etc/oxiderp/oxiderp.env
ExecStart=/usr/local/bin/oxiderp-core
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/oxiderp

[Install]
WantedBy=multi-user.target
